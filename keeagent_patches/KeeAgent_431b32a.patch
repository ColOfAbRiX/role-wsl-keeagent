diff --git a/build-wsl.sh b/build-wsl.sh
new file mode 100755
index 0000000..23db3bf
--- /dev/null
+++ b/build-wsl.sh
@@ -0,0 +1,42 @@
+#!/bin/bash -x
+
+set -euo pipefail
+
+SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+
+sudo apt-get install -y \
+    apt-transport-https \
+    ca-certificates \
+    dirmngr \
+    gnupg \
+    software-properties-common \
+    keepass2
+
+if ! command -v mono &>/dev/null; then
+    sudo apt-key adv --keyserver hkp://keyserver.ubuntu.com:80 --recv-keys 3FA7E0328081BFF6A14DA29AA6A19B38D3D831EF
+    echo "deb [arch=amd64] https://download.mono-project.com/repo/ubuntu stable-focal main" | sudo tee /etc/apt/sources.list.d/mono-official-stable.list
+    sudo apt-get update
+    sudo apt-get install -y mono-complete
+fi
+
+NUGET_EXE="${SCRIPT_DIR}/nuget.exe"
+if [ ! -f "$NUGET_EXE" ]; then
+    wget -q -O "$NUGET_EXE" https://dist.nuget.org/win-x86-commandline/latest/nuget.exe
+fi
+
+BC_DLL="/usr/lib/cli/bccrypto-csharp/BouncyCastle.dll"
+if [ ! -f "$BC_DLL" ]; then
+    if apt-cache show libbccrypto-csharp-cil &>/dev/null 2>&1 \
+        && apt-cache show libbccrypto-csharp-cil 2>&1 | grep -q "^Package:"; then
+        sudo apt-get install -y libbccrypto-csharp-cil
+    else
+        NUGET_TMP="/tmp/nuget_pkgs_keeagent"
+        mono "$NUGET_EXE" install Portable.BouncyCastle -Version 1.9.0 -OutputDirectory "$NUGET_TMP"
+
+        sudo mkdir -p /usr/lib/cli/bccrypto-csharp
+        sudo cp "$NUGET_TMP/Portable.BouncyCastle.1.9.0/lib/net40/BouncyCastle.Crypto.dll" "$BC_DLL"
+    fi
+fi
+
+cd "$SCRIPT_DIR"
+msbuild /property:Configuration=Release KeeAgent.sln
