+    /// <summary>
+    /// Resolves the configured socket bind address from Options.
+    /// Returns null for default (loopback), or the resolved IPAddress.
+    /// </summary>
+    private IPAddress ResolveSocketBindAddress()
+    {
+        var bindType = Options.SocketBindType;
+        var bindValue = Options.SocketBindValue;
+        if (string.IsNullOrEmpty(bindType) || string.IsNullOrEmpty(bindValue))
+            return null; // default: loopback
+
+        if (bindType == "IpAddress")
+        {
+            IPAddress addr;
+            if (IPAddress.TryParse(bindValue, out addr))
+                return addr;
+
+            MessageService.ShowWarning("KeeAgent: Invalid socket bind IP address:", bindValue);
+            return null;
+        }
+
+        if (bindType == "NetworkInterface")
+        {
+            foreach (var iface in NetworkInterface.GetAllNetworkInterfaces())
+            {
+                if (iface.Name == bindValue)
+                {
+                    foreach (var unicast in iface.GetIPProperties().UnicastAddresses)
+                    {
+                        if (unicast.Address.AddressFamily == AddressFamily.InterNetwork)
+                            return unicast.Address;
+                    }
+                    MessageService.ShowWarning("KeeAgent: No IPv4 address found on network interface:", bindValue);
+                    return null;
+                }
+            }
+            MessageService.ShowWarning("KeeAgent: Network interface not found:", bindValue);
+            return null;
+        }
+        return null;
+    }
+
